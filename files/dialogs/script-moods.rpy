# game/dialogs/script-moods.rpy:314
translate chinese s_mood_sick_be210dcc:

    # s bbhajoa "I hope you’re feeling at least somewhat okay, maybe you should go rest for a little while?"
    s bbhajoa "希望你身体还没事……或许你应该去休息一下？"

# game/dialogs/script-moods.rpy:315
translate chinese s_mood_sick_06a2cefd:

    # s abhaiaa "I’ll wait for you, that's not a problem for me."
    s abhaiaa "我就在这儿等你，这对我不是什么问题。"

# game/dialogs/script-moods.rpy:316
translate chinese s_mood_sick_491bafb6:

    # s bbgbica "But I really care about your health, [player], {w=0.5}{nw}"
    s bbgbica "但我真的很在乎你的健康，[player]，{w=0.5}{nw}"

# game/dialogs/script-moods.rpy:317
translate chinese s_mood_sick_c4a257e6:

    # extend bbgccoa "and I don't think sitting in front of a screen will get you healed up any quicker!"
    extend bbgccoa "而且就这样坐在屏幕跟前应该也缓解不了你的恶心！"

# game/dialogs/script-moods.rpy:318
translate chinese s_mood_sick_f4988f04:

    # s bbhfaaa "I'm not going anywhere, {w=0.5}{nw}"
    s bbhfaaa "我哪儿都不会去的，{w=0.5}{nw}"

# game/dialogs/script-moods.rpy:319
translate chinese s_mood_sick_63541f8c:

    # extend abhfcaa "and we can talk whenever you feel up to it again!"
    extend abhfcaa "等你好点儿了我们可以接着聊的！"

# game/dialogs/script-moods.rpy:320
translate chinese s_mood_sick_29582eb1:

    # s abhfaoa "Get well soon, [player]!"
    s abhfaoa "那就早日康复，[player]！"

# game/dialogs/script-moods.rpy:336
translate chinese s_mood_nervous_446622f8:

    # s abhfica "Oh? You’re nervous about something [player]? Did something happen?"
    s abhfica "哦？你在紧张什么呢[player]？发生什么事了？"

# game/dialogs/script-moods.rpy:337
translate chinese s_mood_nervous_346a9d04:

    # s abgbica "Whatever it is that’s stressing you, {w=0.5}{nw}"
    s abgbica "不管是什么在压力你，{w=0.5}{nw}"

# game/dialogs/script-moods.rpy:338
translate chinese s_mood_nervous_121aefdd:

    # extend abgbcaa "we’re in this together!"
    extend abgbcaa "至少你还有我同在！"

# game/dialogs/script-moods.rpy:339
translate chinese s_mood_nervous_2be1e2ea:

    # s abbbiaa "But try not to overthink things, {w=0.5}{nw}"
    s abbbiaa "放轻松，别想太多，{w=0.5}{nw}"

# game/dialogs/script-moods.rpy:340
translate chinese s_mood_nervous_363fec4b:

    # extend abbbaca "we often judge ourselves too harshly."
    extend abbbaca "毕竟我们常常对自己太苛刻了。"

# game/dialogs/script-moods.rpy:342
translate chinese s_mood_nervous_26a95063:

    # s abgccab "I truly love you [player], and no matter what happens, I’ll always support you."
    s abgccab "我真的很爱你[player]，无论发生什么，我都会在你身边支持你的。"

# game/dialogs/script-moods.rpy:344
translate chinese s_mood_nervous_13ea5c12:

    # s abgccaa "No matter what happens, I’ll always support you."
    s abgccaa "无论发生什么，我都会在你身边支持你的。"

# game/dialogs/script-moods.rpy:360
translate chinese s_mood_unmotivated_f3e935e0:

    # s bbhaaab "Aww... I understand that feeling all too well, {w=0.5}{nw}"
    s bbhaaab "啊……我可太明白这种感受了，{w=0.5}{nw}"

# game/dialogs/script-moods.rpy:361
translate chinese s_mood_unmotivated_40402da1:

    # extend abbcaaa "but I'm sure you'll get your motivation back, [player]."
    extend abbcaaa "不过我相信你很快就能找回动力的，[player]。"

# game/dialogs/script-moods.rpy:362
translate chinese s_mood_unmotivated_bb3a4981:

    # s abbbaca "Maybe you could try to write a poem about your emotions, just like I always did?"
    s abbbaca "你可以给自己的感受写写诗，就像我一样？"

# game/dialogs/script-moods.rpy:363
translate chinese s_mood_unmotivated_3844595d:

    # s abbcaca "I found it helpful to let it all out in some way and be honest with myself."
    s abbcaca "对自己诚实些，把自己的感受发泄出来，我觉得这样很有用的。"

# game/dialogs/script-moods.rpy:364
translate chinese s_mood_unmotivated_9621c3fa:

    # s abgccoa "And it also might help you find some inspiration to get you motivated again!"
    s abgccoa "顺便还能找到一些灵感帮你恢复精力！"

# game/dialogs/script-moods.rpy:365
translate chinese s_mood_unmotivated_5622c906:

    # s abbbaaa "Just don't ever give up on anything you do!"
    s abbbaaa "不要放弃你的追求！"

# game/dialogs/script-moods.rpy:366
translate chinese s_mood_unmotivated_2cd6e51d:

    # s abhfaoa "Keep going, and with enough determination, I know you'll reach your goals!"
    s abhfaoa "一直走下去，保持决心，你一定能达成想要的目标的！"

# game/dialogs/script-moods.rpy:367
translate chinese s_mood_unmotivated_fa508358:

    # s abbbaaa "And If you need to, there's no shame in giving yourself some time to rest and take a break from things as well."
    s abbbaaa "必要的话也可以休息休息，让自己从这些繁杂中抽身，这也没什么大不了的。"

# game/dialogs/script-moods.rpy:368
translate chinese s_mood_unmotivated_71af5fa0:

    # s abgccoa "After a while, some motivation should pop back up into that unmotivated brain of yours!"
    s abgccoa "过段时间你的大脑就会充满能量啦！"

# game/dialogs/script-moods.rpy:384
translate chinese s_mood_depressed_fc37d876:

    # s bbhfjla "[player]... I'm so sorry to hear that."
    s bbhfjla "[player]……很抱歉听到这种消息。"

# game/dialogs/script-moods.rpy:385
translate chinese s_mood_depressed_5ffaa228:

    # s bbhfica "Please remember that no matter what your mind tells you, you are an amazing, sweet and lovely person."
    s bbhfica "无论你的大脑想给你灌输什么思想，你在我眼中依然完美，依然活泼可爱。"

# game/dialogs/script-moods.rpy:386
translate chinese s_mood_depressed_43b99b44:

    # s bbhaila "Don't let those bad thoughts, those rainclouds, control you."
    s bbhaila "别让那些糟糕的思想和乌云掌控你。"

# game/dialogs/script-moods.rpy:387
translate chinese s_mood_depressed_d2a7f88b:

    # s bbbbaca "Trust me when I say that there are people who care about you and want to help you."
    s bbbbaca "相信我，我说过世上总有人愿意关心你照顾你的。"

# game/dialogs/script-moods.rpy:388
translate chinese s_mood_depressed_37471f34:

    # s "You are not alone, never ever, okay?"
    s "你从来，也永远不可能孤独，明白吗？"

# game/dialogs/script-moods.rpy:389
translate chinese s_mood_depressed_61525718:

    # s bbbcjfag "Don't ever do the same horrible mistakes I did. Please reach out to someone and vent about your emotions… it really might help you feel better."
    s bbbcjfag "万万不要重蹈我的覆辙。主动向外寻求帮助，找人发泄你的情感……这样真的能缓和很多。"

# game/dialogs/script-moods.rpy:391
translate chinese s_mood_depressed_b18701ef:

    # s bbgbacb "[player]... I love you so, so much. I’m always here for you, through the good times and the not-so-good times, and I’ll try my best to help you as much as I can from here."
    s bbgbacb "[player]……我真的，真心非常爱你。我会一直陪你，无论顺风逆风我都会随你而行。"

# game/dialogs/script-moods.rpy:392
translate chinese s_mood_depressed_1d573dd5:

    # s bbbbaaa "Just don't give up and keep going forward okay?"
    s bbbbaaa "只是不要放弃，好吗？"

# game/dialogs/script-moods.rpy:393
translate chinese s_mood_depressed_e1de2c58:

    # s bbhfica "Because no matter how loud those rainclouds get and no matter how hard things seem to be… there is always a glimpse of hope. A light at the end of the tunnel."
    s bbhfica "哪怕乌云喧嚣，深陷黑暗……在隧道的尽头，总有一束希望的曙光。"

# game/dialogs/script-moods.rpy:394
translate chinese s_mood_depressed_fdd9f344:

    # s bbhfifa "Giving up is the worst thing you can do… I learned that myself..."
    s bbhfifa "而你最不该做的就是放弃……这方面我可是学到教训了……"

# game/dialogs/script-moods.rpy:395
translate chinese s_mood_depressed_3c9029c2:

    # s bbbbica "So if you ever need to spend some time with me then go ahead and we can just talk, alright?"
    s bbbbica "所以如果你需要我的话，我们可以一块聊聊天，好吗？"

# game/dialogs/script-moods.rpy:396
translate chinese s_mood_depressed_5f4e99c6:

    # s bbgcaaa "Remember I am always here if you need anything, no matter how small."
    s bbgcaaa "如果你有什么请求，哪怕它再微小，我也随时都在。"

# game/dialogs/script-moods.rpy:398
translate chinese s_mood_depressed_6e370263:

    # s bbfcaab "I love you [player], forever and ever."
    s bbfcaab "我爱你，[player]，永远永远。"

# game/dialogs/script-moods.rpy:413
translate chinese s_mood_nostalgic_e25cec73:

    # s abagaca "Nostalgic, huh? I know that feeling."
    s abagaca "怀念？我理解这种感受的。"

# game/dialogs/script-moods.rpy:414
translate chinese s_mood_nostalgic_6ae3a2d5:

    # s abhaaca "Sometimes I find myself thinking about the literature club. Even the bittersweet moments feel warm now, in a weird way."
    s abhaaca "有时候我会去想文学部的事。哪怕记忆有些悲喜交加，我也多少感到怪温暖的。"

# game/dialogs/script-moods.rpy:415
translate chinese s_mood_nostalgic_7d6e65e2:

    # s bbaaaoa "It's like... you know something is over, and you can't go back, but you're happy it happened."
    s bbaaaoa "就像是……你知道已经结束了，你回不去了；但能见证过它发生，你仍然很开心。"

# game/dialogs/script-moods.rpy:416
translate chinese s_mood_nostalgic_b8600718:

    # s "Do you ever feel that way about certain memories, [player]?{nw}"
    s "你有这样特别的记忆吗，[player]？{nw}"

# game/dialogs/script-moods.rpy:420
translate chinese s_mood_nostalgic_70a09f98:

    # s "Do you ever feel that way about certain memories, [player]?{fast}" nointeract
    s "你有这样特别的记忆吗，[player]？{fast}" nointeract

# game/dialogs/script-moods.rpy:423
translate chinese s_mood_nostalgic_e51972cc:

    # s abbbaca "Exactly! It's a little sad, but also comforting."
    s abbbaca "对呀！虽然有些难受，但仍然会让你欣慰。"

# game/dialogs/script-moods.rpy:424
translate chinese s_mood_nostalgic_eb1837cc:

    # s abaaaca "It's proof that we've lived and felt things deeply. I think that's beautiful."
    s abaaaca "这正是我们深刻生活过、感受过的证明。简直太美了。"

# game/dialogs/script-moods.rpy:425
translate chinese s_mood_nostalgic_a624bad7:

    # s abhaaca "It makes me appreciate the now even more."
    s abhaaca "这也让我更加珍惜眼下的时光了。"

# game/dialogs/script-moods.rpy:428
translate chinese s_mood_nostalgic_a223117b:

    # s bbaaaoa "I can understand that. Sometimes looking back is hard."
    s bbaaaoa "明白的。有些记忆简直不堪回首。"

# game/dialogs/script-moods.rpy:429
translate chinese s_mood_nostalgic_8d6072ad:

    # s abhaaca "But it can also remind us of how far we've come, you know?"
    s abhaaca "但这也证明我们经历了多少沧桑，明白吧？"

# game/dialogs/script-moods.rpy:430
translate chinese s_mood_nostalgic_ec22b94c:

    # s abhfaoa "Just know that it's okay to feel that way. We can make new memories to look back on, right here."
    s abhfaoa "有这种感受也没关系的。我们可以从当下开始创造新的记忆。"

# game/dialogs/script-moods.rpy:434
translate chinese s_mood_nostalgic_8887d642:

    # s abhfmkb "Oh, [player]...!"
    s abhfmkb "噢，[player]……！"

# game/dialogs/script-moods.rpy:435
translate chinese s_mood_nostalgic_addcb18a:

    # s abagcka "Ehehehe, you always know just what to say to make me blush~"
    s abagcka "欸嘿嘿，你怎么这么容易就让我脸红啊~"

# game/dialogs/script-moods.rpy:436
translate chinese s_mood_nostalgic_918ccadc:

    # s abgccob "I feel the same way. Every moment with you feels special."
    s abgccob "我也有这种感觉，和你在一起的每一刻都是如此特别。"

# game/dialogs/script-moods.rpy:437
translate chinese s_mood_nostalgic_505aebc9:

    # s abfccab "These are the memories I'll treasure the most... forever and ever."
    s abfccab "这些记忆我会珍藏起来……直到永远。"

# game/dialogs/script-moods.rpy:438
translate chinese s_mood_nostalgic_4029b35d:

    # s abgccaa "Thanks for sharing that with me. It feels like I can talk to you about anything."
    s abgccaa "谢谢你能对我说这些话。感觉自己什么事情都能和你聊了呢。"

# game/dialogs/script-moods.rpy:441
translate chinese s_mood_nostalgic_6fc45aed:

    # s abgccaa "Thanks for sharing that with me. It's nice to know we can talk about these things."
    s abgccaa "谢谢你能对我说这些话，能聊聊这些事情也是很好的。"

